# ── Copy this to .env for development ─────────────────────────────────────────
APP_ENV=development

# Database (local)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/academic_db

# Firebase DEV project
# Get from: Firebase Console → your DEV project → Project Settings → Service Accounts → Generate key
# Convert to single line: cat serviceAccountKey.dev.json | python3 -c "import json,sys; print(json.dumps(json.load(sys.stdin)))"
FIREBASE_CREDENTIALS_JSON={}

# Get from: Firebase Console → your DEV project → Project Settings → General → Web API Key
FIREBASE_WEB_API_KEY=AIza...

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MAX_TOKENS=600

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OneSignal (can use same app for dev/prod or create separate)
ONESIGNAL_APP_ID=your_app_id
ONESIGNAL_API_KEY=your_rest_api_key

SECRET_KEY=generate-a-random-string-here
