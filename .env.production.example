# ── Copy this to .env.production for production (Render) ──────────────────────
APP_ENV=production

# Database (Render managed DB)
DATABASE_URL=postgresql://academic_user:xxxx@dpg-xxxx.oregon-postgres.render.com/academic

# Firebase PROD project
FIREBASE_CREDENTIALS_JSON={}
FIREBASE_WEB_API_KEY=AIza...

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MAX_TOKENS=600

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OneSignal
ONESIGNAL_APP_ID=your_app_id
ONESIGNAL_API_KEY=your_rest_api_key

SECRET_KEY=generate-a-random-string-here
